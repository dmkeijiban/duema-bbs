NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=your_hcaptcha_site_key
HCAPTCHA_SECRET_KEY=your_hcaptcha_secret_key

# Seed Cron 認証トークン（GitHub Actions → Vercel API /api/seed の認証に使用）
# 生成例: openssl rand -hex 32
# 設定場所: Vercel Dashboard > Settings > Environment Variables (Production)
#           GitHub > Settings > Secrets and variables > Actions > CRON_SECRET
CRON_SECRET=your_cron_secret_for_seed_api

# X自動運用システム (Typefully API)
# https://app.typefully.com/settings/api から取得
TYPEFULLY_API_KEY=your_typefully_api_key

# Apify API トークン（Xリプライ取得機能で使用）
# https://console.apify.com/settings/integrations から取得
APIFY_TOKEN=your_apify_api_token

# X投稿→掲示板スレ自動作成 内部API認証トークン
# 生成例: openssl rand -hex 32
# 設定場所: Vercel Dashboard > Settings > Environment Variables (Production)
#           scripts/post-forum-from-csv.mjs を実行する環境の .env.local
INTERNAL_POST_SECRET=your_internal_post_secret

# 掲示板APIのベースURL（スクリプト実行時に使用）
# 本番: https://www.duema-bbs.com
# ローカル: http://localhost:3000
FORUM_API_BASE_URL=https://www.duema-bbs.com

# 通常は有効。削除要請・仕様変更時のみ false で緊急停止
CARD_IMAGES_ENABLED=true
# カタログ検証取得時のUser-Agent連絡先
CARD_CATALOG_CONTACT=
